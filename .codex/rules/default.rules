# OpenAI Codex CLI — execpolicy rules for this repo (Starlark).
#
# Loaded from .codex/rules/*.rules when the project is trusted. These gate command
# EXECUTION (not file reads — Codex has no per-file read denylist; keep secrets out of
# the tree and rely on network_access=false so reads can't be exfiltrated).
#
# decision: "allow" (run, no prompt) | "prompt" (ask each time) | "forbidden" (block).
# When rules overlap the most restrictive wins: forbidden > prompt > allow.
# Matching is token-prefix and best-effort (e.g. ["rm","-rf"] won't catch "rm -fr").
# Test: codex execpolicy check --pretty --rules .codex/rules/default.rules -- <command>
# Docs: https://developers.openai.com/codex/rules

# --- Block destructive / exfiltration-prone commands outright ---
prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "No recursive force-delete; remove files deliberately instead.",
)
prefix_rule(
    pattern = ["curl"],
    decision = "forbidden",
    justification = "Use built-in web tools; no ad-hoc network access from the shell.",
)
prefix_rule(
    pattern = ["wget"],
    decision = "forbidden",
    justification = "Use built-in web tools; no ad-hoc network access from the shell.",
)

# --- Require explicit approval for outward-facing / irreversible VCS actions ---
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Pushing is outward-facing; confirm before publishing.",
)
prefix_rule(
    pattern = ["jj", "git", "push"],
    decision = "prompt",
    justification = "Pushing is outward-facing; confirm before publishing.",
)
