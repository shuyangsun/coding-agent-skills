{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./.agents/skills/coding-style/styles/react.oxlintrc.json",
    "./.agents/skills/coding-style/styles/typescript.oxlintrc.json"
  ],
  "plugins": ["typescript", "react", "import"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": ["**/routeTree.gen.ts", "**/*.gen.ts"]
}
