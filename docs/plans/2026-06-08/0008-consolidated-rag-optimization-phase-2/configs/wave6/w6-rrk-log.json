{
  "rag_config_id": "w6-rrk-log",
  "embedding": {
    "dense_model": "BAAI/bge-small-en-v1.5",
    "dense_dim": 384,
    "distance": "cosine",
    "sparse_model": "Qdrant/bm25"
  },
  "chunker": {
    "strategy": "heading",
    "size": 350,
    "overlap": 40,
    "min_words": 80,
    "code_size": 120,
    "code_overlap": 20
  },
  "hybrid": {
    "fusion": "rrf",
    "prefetch": 60
  },
  "rerank": {
    "enabled": true,
    "backend": "infinity",
    "endpoint": "http://localhost:7997",
    "model": "bge-reranker-v2-m3",
    "top_n": 50,
    "gate": {
      "log_only": true
    }
  },
  "top_k": 20,
  "retrieval_mode": "hybrid",
  "index_mode": "combined",
  "contextual_header": true,
  "contextual_llm": {
    "enabled": true,
    "model": "gemma-4",
    "apply_to": ["md", "code"],
    "prompt_version": "v1"
  },
  "arm": "w6-rrk-log",
  "_doc": "w4llm-rrk (always-rerank) + rerank.gate.log_only: logs first-pass confidence features (agree10/head_share/nfiles10/d_top/d_gap/s_top) per query into route.feat without changing behavior. Dev rows feed the offline threshold search that freezes w6-rrk-gate."
}
