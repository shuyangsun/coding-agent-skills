{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun run *)",
      "Bash(bun add *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(bash .agents/skills/vcs/scripts/isolate.sh *)",
      "Bash(bash .agents/skills/vcs/scripts/integrate.sh *)",
      "Bash(bash .agents/skills/vcs/scripts/session-start.sh *)",
      "Bash(bash .agents/skills/vcs/scripts/rename-work.sh *)",
      "Bash(jj root *)",
      "Bash(jj status *)",
      "Bash(jj log *)",
      "Bash(jj diff *)",
      "Bash(jj show *)",
      "Bash(jj workspace list *)",
      "Bash(jj bookmark list *)",
      "Bash(jj fix *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.agents/skills/vcs/scripts/session-start.sh",
            "args": ["--hook", "claude", "--ide", "claude"],
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.agents/skills/vcs/scripts/vcs-check.sh",
            "args": ["hook", "--agent", "claude"],
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.agents/skills/vcs/scripts/vcs-check.sh",
            "args": ["hook", "--agent", "claude"],
            "timeout": 30
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.agents/skills/vcs/scripts/vcs-check.sh",
            "args": ["hook", "--agent", "claude"],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
