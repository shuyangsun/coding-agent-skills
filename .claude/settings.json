{
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun run *)",
      "Bash(bun add *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(jj status *)",
      "Bash(jj log *)",
      "Bash(jj diff *)",
      "Bash(jj show *)",
      "Bash(jj commit *)",
      "Bash(jj describe *)",
      "Bash(jj new *)",
      "Bash(jj bookmark *)",
      "Bash(jj fix *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  }
}
