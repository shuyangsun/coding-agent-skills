{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:coding-agent-skills:export-raw-transcript:metadata:1",
  "title": "Export Raw Transcript Metadata",
  "description": "Metadata sidecar written by export-raw-transcript.sh.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "short_name",
    "summary",
    "exported_at_utc",
    "exported_at_unix",
    "exported_at_local",
    "timezone",
    "agent",
    "os",
    "repo",
    "author",
    "source",
    "session",
    "export"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "title": {
      "$ref": "#/$defs/nullableString"
    },
    "short_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 60,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "summary": {
      "$ref": "#/$defs/nullableString"
    },
    "exported_at_utc": {
      "$ref": "#/$defs/utcDateTime"
    },
    "exported_at_unix": {
      "type": "integer",
      "minimum": 0
    },
    "exported_at_local": {
      "$ref": "#/$defs/nullableLocalDateTime"
    },
    "timezone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "abbreviation", "utc_offset"],
      "properties": {
        "name": {
          "$ref": "#/$defs/nullableString"
        },
        "abbreviation": {
          "$ref": "#/$defs/nullableString"
        },
        "utc_offset": {
          "$ref": "#/$defs/nullableUtcOffset"
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vendor",
        "tool",
        "tool_version",
        "model",
        "effort",
        "entrypoint",
        "session_id",
        "detected_via"
      ],
      "properties": {
        "vendor": {
          "$ref": "#/$defs/nullableString"
        },
        "tool": {
          "type": "string",
          "enum": [
            "claude-code",
            "codex-cli",
            "cursor-agent",
            "antigravity",
            "gemini-cli"
          ]
        },
        "tool_version": {
          "$ref": "#/$defs/nullableString"
        },
        "model": {
          "$ref": "#/$defs/nullableString"
        },
        "effort": {
          "$ref": "#/$defs/nullableString"
        },
        "entrypoint": {
          "$ref": "#/$defs/nullableString"
        },
        "session_id": {
          "$ref": "#/$defs/nullableString"
        },
        "detected_via": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "os": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kernel", "platform", "arch", "hostname"],
      "properties": {
        "kernel": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "$ref": "#/$defs/nullableString"
        },
        "hostname": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "vcs", "ref", "commit", "remote"],
      "properties": {
        "root": {
          "$ref": "#/$defs/nullableString"
        },
        "vcs": {
          "type": ["string", "null"],
          "enum": ["git", "jujutsu", null]
        },
        "ref": {
          "$ref": "#/$defs/nullableString"
        },
        "commit": {
          "$ref": "#/$defs/nullableString"
        },
        "remote": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "email"],
      "properties": {
        "name": {
          "$ref": "#/$defs/nullableString"
        },
        "email": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "filename",
        "format",
        "extension",
        "bytes",
        "lines",
        "sha256",
        "modified_utc"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "$ref": "#/$defs/nullableString"
        },
        "extension": {
          "$ref": "#/$defs/nullableString"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "lines": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "modified_utc": {
          "$ref": "#/$defs/nullableUtcDateTime"
        }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_utc",
        "ended_utc",
        "records",
        "user_turns",
        "assistant_turns",
        "user_records",
        "assistant_records",
        "models",
        "tokens",
        "title",
        "agent_name",
        "bridge_session_id"
      ],
      "properties": {
        "started_utc": {
          "$ref": "#/$defs/nullableUtcDateTimeMs"
        },
        "ended_utc": {
          "$ref": "#/$defs/nullableUtcDateTimeMs"
        },
        "records": {
          "description": "Total JSONL records in the transcript (all record types).",
          "$ref": "#/$defs/nullableNonNegInt"
        },
        "user_turns": {
          "description": "Human input turns: messages the user actually sent (typed messages and slash commands). Excludes tool-result records, injected meta/compact-summary records, and sub-agent traffic. Changed meaning in schema_version 2; in v1 this field held the raw type=user record count (now reported as user_records).",
          "$ref": "#/$defs/nullableNonNegInt"
        },
        "assistant_turns": {
          "description": "Main-agent turn count: distinct assistant message ids, excluding sub-agent (sidechain) and synthetic messages. One API response logged across several records (a text block plus per-tool_use records) counts once. Changed meaning in schema_version 2; in v1 this field held the raw type=assistant record count (now reported as assistant_records).",
          "$ref": "#/$defs/nullableNonNegInt"
        },
        "user_records": {
          "description": "Raw count of type=user JSONL records, including tool results and injected records. This is the number v1 reported as user_turns.",
          "$ref": "#/$defs/nullableNonNegInt"
        },
        "assistant_records": {
          "description": "Raw count of type=assistant JSONL records; streaming/tool-use splits make this larger than assistant_turns. This is the number v1 reported as assistant_turns.",
          "$ref": "#/$defs/nullableNonNegInt"
        },
        "models": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokens": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "input",
            "output",
            "cache_read",
            "cache_creation",
            "total"
          ],
          "properties": {
            "input": {
              "$ref": "#/$defs/nullableNonNegInt"
            },
            "output": {
              "$ref": "#/$defs/nullableNonNegInt"
            },
            "cache_read": {
              "$ref": "#/$defs/nullableNonNegInt"
            },
            "cache_creation": {
              "$ref": "#/$defs/nullableNonNegInt"
            },
            "total": {
              "$ref": "#/$defs/nullableNonNegInt"
            }
          }
        },
        "title": {
          "$ref": "#/$defs/nullableString"
        },
        "agent_name": {
          "$ref": "#/$defs/nullableString"
        },
        "bridge_session_id": {
          "$ref": "#/$defs/nullableString"
        }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transcript_file", "metadata_file", "dest_dir"],
      "properties": {
        "transcript_file": {
          "type": "string",
          "minLength": 1
        },
        "metadata_file": {
          "type": "string",
          "pattern": "-metadata\\.json$"
        },
        "dest_dir": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "utcDateTime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "nullableUtcDateTime": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "nullableUtcDateTimeMs": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"
    },
    "nullableNonNegInt": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "nullableLocalDateTime": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}[+-][0-9]{2}:[0-9]{2}$"
    },
    "nullableUtcOffset": {
      "type": ["string", "null"],
      "pattern": "^[+-][0-9]{2}:[0-9]{2}$"
    }
  }
}
